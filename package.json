{
  "name": "iobroker.miner",
  "version": "1.0.4",
  "description": "Interact with different crypto miner apis",
  "author": {
    "name": "SimonFischer04",
    "email": "simi.fischa@gmail.com"
  },
  "homepage": "https://github.com/SimonFischer04/ioBroker.miner",
  "license": "GPL-3.0-only",
  "keywords": [
    "ioBroker",
    "crypto",
    "bitcoin",
    "miner",
    "braiins",
    "luxor"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/SimonFischer04/ioBroker.miner"
  },
  "engines": {
    "node": ">= 22"
  },
  "dependencies": {
    "@iobroker/adapter-core": "^3.4.1",
    "@iobroker/dm-utils": "^3.0.19",
    "type-fest": "^5.7.0",
    "@grpc/grpc-js": "^1.14.3",
    "@grpc/proto-loader": "^0.8.0"
  },
  "devDependencies": {
    "@alcalzone/release-script": "^5.2.1",
    "@alcalzone/release-script-plugin-iobroker": "^5.2.0",
    "@alcalzone/release-script-plugin-license": "^5.2.0",
    "@alcalzone/release-script-plugin-manual-review": "^5.2.0",
    "@iobroker/adapter-dev": "^1.5.0",
    "@iobroker/eslint-config": "^2.3.4",
    "@iobroker/testing": "^5.2.2",
    "@tsconfig/node22": "^22.0.5",
    "@types/node": "^22.20.1",
    "nyc": "^18.0.0",
    "rimraf": "^6.1.3",
    "source-map-support": "^0.5.21",
    "ts-node": "^10.9.2",
    "typescript": "~5.9.3"
  },
  "main": "build/main.js",
  "files": [
    "admin{,/!(src)/**}/!(tsconfig|tsconfig.*|.eslintrc).{json,json5}",
    "admin{,/!(src)/**}/*.{html,css,png,svg,jpg,js}",
    "build/",
    "www/",
    "io-package.json",
    "LICENSE"
  ],
  "scripts": {
    "gen": "rimraf src/lib/generated/bos-api && mkdir -p src/lib/generated/bos-api/proto/bos src/lib/generated/bos-api/types && cp -r external/bos/proto/. src/lib/generated/bos-api/proto/bos && cd src/lib/generated/bos-api/proto && proto-loader-gen-types --grpcLib @grpc/grpc-js --longs Number --enums Number --oneofs -I . -O ../types bos/version.proto bos/v1/*.proto",
    "dev": "dev-server watch",
    "startDev": "dev-server watch --noStart",
    "prebuild": "rimraf build",
    "build": "build-adapter ts",
    "postbuild": "cp -r src/lib/i18n build/lib/i18n && mkdir -p build/lib/generated/bos-api/proto && cp -r src/lib/generated/bos-api/proto/. build/lib/generated/bos-api/proto",
    "watch": "build-adapter ts --watch",
    "prebuild:ts": "rimraf build",
    "build:ts": "build-adapter ts",
    "postbuild:ts": "cp -r src/lib/i18n build/lib/i18n && mkdir -p build/lib/generated/bos-api/proto && cp -r src/lib/generated/bos-api/proto/. build/lib/generated/bos-api/proto",
    "watch:ts": "build-adapter ts --watch",
    "test:unit": "mocha --config test/mocharc.custom.json src/**/*.test.ts",
    "test:package": "mocha test/package --exit",
    "test:integration": "mocha test/integration --exit",
    "test": "npm run test:unit && npm run test:package",
    "check": "tsc --noEmit",
    "coverage": "nyc npm run test:unit",
    "lint": "eslint -c eslint.config.mjs .",
    "translate": "translate-adapter",
    "release": "release-script"
  },
  "nyc": {
    "include": [
      "src/**/*.ts"
    ],
    "exclude": [
      "src/**/*.test.ts"
    ],
    "extension": [
      ".ts"
    ],
    "require": [
      "ts-node/register"
    ],
    "reporter": [
      "text-summary",
      "html"
    ],
    "sourceMap": true,
    "instrument": true
  },
  "bugs": {
    "url": "https://github.com/SimonFischer04/ioBroker.miner/issues"
  },
  "readmeFilename": "README.md"
}
